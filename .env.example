# ============================================================
# SIKU Backend Configuration
# ============================================================
# IMPORTANT: Copy this file to .env and fill in your API keys
# NEVER commit .env file to git
# ============================================================

# OpenRouter - AI Chat API
# Get API key from: https://openrouter.ai/api/keys
# These keys are used by backend server only
OPENROUTER_API_KEY=sk-or-v1-your_actual_key_here

# FlowKirim - WhatsApp Messaging API  
# Get API key from: https://flowkirim.com/dashboard
# These keys are used by backend server only
FLOWKIRIM_API_KEY=your_actual_flowkirim_key_here

# Server Configuration
PORT=5000
NODE_ENV=development
SITE_URL=http://localhost:3000
SITE_NAME=SIKU Chatbot

# ============================================================
# SECURITY NOTES:
# ============================================================
# 1. This file contains sensitive credentials
# 2. NEVER commit .env to version control
# 3. Add .env to .gitignore (already done)
# 4. API keys only accessed by backend (server.js)
# 5. Frontend never sees these keys
# 6. Use environment variables in production
# ============================================================